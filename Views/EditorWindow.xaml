<Window x:Class="MoodyClone.Views.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinTeleprompter"
        Width="860" Height="660"
        MinWidth="580" MinHeight="400"
        Background="#0A0A0F"
        Foreground="White"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>

        <!-- iOS-style toolbar button -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background" Value="#18FFFFFF"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}"
                                BorderBrush="#22FFFFFF" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#28FFFFFF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#38FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#40FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Green CTA button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#30D158"/>
            <Setter Property="Foreground" Value="#0A0A0F"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="14" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#30D158" BlurRadius="14" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#36E862"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2ABD4E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon-only round button -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="#18FFFFFF"/>
            <Setter Property="Foreground" Value="#AAFFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Width="34" Height="34"
                                BorderBrush="#22FFFFFF" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#28FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>   <!-- Editor -->
            <RowDefinition Height="32"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ===== TOOLBAR ===== -->
        <Border Grid.Row="0"
                Background="#12FFFFFF"
                BorderBrush="#0EFFFFFF"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <!-- App name -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <Ellipse Width="10" Height="10" Fill="#30D158" Margin="0,0,10,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#30D158" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Text="WinTeleprompter"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="#EEFFFFFF"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right controls -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                    <!-- Font size controls -->
                    <Button Content="A−" Style="{StaticResource IconBtn}"
                            Click="FontDecrease_Click" ToolTip="Decrease font size"
                            Margin="0,0,6,0" FontSize="11"/>
                    <Button Content="A+" Style="{StaticResource IconBtn}"
                            Click="FontIncrease_Click" ToolTip="Increase font size"
                            Margin="0,0,14,0" FontSize="11"/>

                    <!-- Settings -->
                    <Button Content="⚙" Style="{StaticResource ToolBtn}"
                            Click="Settings_Click" ToolTip="Settings"
                            Padding="12,8" Margin="0,0,8,0"/>

                    <!-- Start Prompter -->
                    <Button x:Name="StartPrompterBtn"
                            Content="▶  Start Prompter"
                            Style="{StaticResource PrimaryBtn}"
                            Click="StartPrompter_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== EDITOR ===== -->
        <Grid Grid.Row="1">
            <!-- Subtle radial highlight in the editor area -->
            <Border>
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.1" GradientOrigin="0.5,0.1" RadiusX="0.8" RadiusY="0.5">
                        <GradientStop Color="#0A1A2A3A" Offset="0"/>
                        <GradientStop Color="#000A0A0F" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBox x:Name="ScriptEditor"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Background="Transparent"
                         Foreground="#F0FFFFFF"
                         CaretBrush="#30D158"
                         BorderThickness="0"
                         FontSize="18"
                         FontFamily="Segoe UI Variable Text, Segoe UI"
                         FontWeight="Light"
                         Padding="56,36"
                         VerticalAlignment="Stretch"
                         TextChanged="ScriptEditor_TextChanged"
                         SpellCheck.IsEnabled="True">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                                      HorizontalScrollBarVisibility="Hidden"
                                                      VerticalScrollBarVisibility="Hidden"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </ScrollViewer>

            <!-- Placeholder text -->
            <TextBlock x:Name="PlaceholderText"
                       Text="Start typing your script here..."
                       FontSize="18" FontWeight="Light"
                       Foreground="#22FFFFFF"
                       Padding="56,36"
                       VerticalAlignment="Top"
                       IsHitTestVisible="False"
                       FontFamily="Segoe UI Variable Text, Segoe UI"/>
        </Grid>

        <!-- ===== STATUS BAR ===== -->
        <Border Grid.Row="2"
                Background="#0CFFFFFF"
                BorderBrush="#0AFFFFFF"
                BorderThickness="0,1,0,0">
            <DockPanel Margin="20,0">
                <!-- Word/char counts -->
                <TextBlock x:Name="WordCount"
                           Text="0 words · 0 characters"
                           FontSize="11" Foreground="#55FFFFFF"
                           VerticalAlignment="Center"/>

                <!-- Autosave indicator -->
                <TextBlock x:Name="SaveIndicator"
                           Text="Saved"
                           FontSize="11" Foreground="#40FFFFFF"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
