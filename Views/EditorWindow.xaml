<Window x:Class="MoodyClone.Views.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MoodyClone"
        Width="900" Height="650"
        MinWidth="600" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        Background="#1C1C1E"
        Foreground="White"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Button Base Style -->
        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#48484A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Start Button Style -->
        <Style x:Key="StartBtn" TargetType="Button" BasedOn="{StaticResource ToolbarBtn}">
            <Setter Property="Background" Value="#30D158"/>
            <Setter Property="Foreground" Value="#1C1C1E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#34E060"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#28B04C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="EditorTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1C1C1E"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="CaretBrush" Value="#30D158"/>
            <Setter Property="SelectionBrush" Value="#5530D158"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,16"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- ====== TOOLBAR ====== -->
        <Border Grid.Row="0" Background="#252528" BorderBrush="#333336" BorderThickness="0,0,0,1">
            <DockPanel Margin="12,0">
                <!-- Left side -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎬" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="MoodyClone" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"
                               Foreground="#E0E0E0"/>
                </StackPanel>

                <!-- Right side -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="A−" Style="{StaticResource ToolbarBtn}" Click="FontDecrease_Click"
                            ToolTip="Decrease font size"/>
                    <TextBlock x:Name="FontSizeLabel" Text="22" FontSize="12" Foreground="#888"
                               VerticalAlignment="Center" Margin="4,0" MinWidth="20" TextAlignment="Center"/>
                    <Button Content="A+" Style="{StaticResource ToolbarBtn}" Click="FontIncrease_Click"
                            ToolTip="Increase font size"/>
                    <Rectangle Width="1" Height="24" Fill="#3A3A3C" Margin="8,0"/>
                    <Button Content="⚙ Settings" Style="{StaticResource ToolbarBtn}" Click="Settings_Click"/>
                    <Button Content="▶ Start Prompter" Style="{StaticResource StartBtn}" Click="StartPrompter_Click"
                            Padding="18,7"/>
                </StackPanel>

                <!-- Spacer -->
                <Border/>
            </DockPanel>
        </Border>

        <!-- ====== EDITOR ====== -->
        <TextBox Grid.Row="1"
                 x:Name="ScriptEditor"
                 Style="{StaticResource EditorTextBox}"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontSize="22"
                 TextChanged="ScriptEditor_TextChanged"
                 SpellCheck.IsEnabled="True">
        </TextBox>

        <!-- ====== STATUS BAR ====== -->
        <Border Grid.Row="2" Background="#252528" BorderBrush="#333336" BorderThickness="0,1,0,0">
            <DockPanel Margin="16,0">
                <TextBlock x:Name="AutosaveIndicator" DockPanel.Dock="Right"
                           Text="Saved" FontSize="11" Foreground="#666"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="WordCount" Text="0 words" FontSize="11" Foreground="#888"/>
                    <TextBlock Text="  ·  " FontSize="11" Foreground="#555"/>
                    <TextBlock x:Name="CharCount" Text="0 characters" FontSize="11" Foreground="#888"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
