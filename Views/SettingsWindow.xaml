<Window x:Class="MoodyClone.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="440" Height="580"
        WindowStartupLocation="CenterOwner"
        Background="#1C1C1E"
        Foreground="White"
        FontFamily="Segoe UI"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#777"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="SettingsCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#3A3A3C"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="Radio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>
        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Background" Value="#30D158"/>
            <Setter Property="Foreground" Value="#1C1C1E"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#34E060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CancelBtn" TargetType="Button">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24" VerticalAlignment="Top">
        <!-- Title -->
        <TextBlock Text="⚙ Settings" FontSize="20" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,24"/>

        <!-- MICROPHONE -->
        <TextBlock Text="MICROPHONE" Style="{StaticResource SectionLabel}"/>
        <ComboBox x:Name="MicSelector" Style="{StaticResource SettingsCombo}" Margin="0,0,0,20"/>

        <!-- TEXT COLOR -->
        <TextBlock Text="TEXT COLOR" Style="{StaticResource SectionLabel}"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <RadioButton x:Name="ColorWhite" Content="White" Style="{StaticResource Radio}" IsChecked="True"/>
            <RadioButton x:Name="ColorYellow" Content="Yellow" Style="{StaticResource Radio}"/>
            <RadioButton x:Name="ColorGreen" Content="Green" Style="{StaticResource Radio}"/>
        </StackPanel>

        <!-- TEXT ALIGNMENT -->
        <TextBlock Text="TEXT ALIGNMENT" Style="{StaticResource SectionLabel}"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <RadioButton x:Name="AlignLeft" Content="◀ Left" Style="{StaticResource Radio}"/>
            <RadioButton x:Name="AlignCenter" Content="▶◀ Center" Style="{StaticResource Radio}" IsChecked="True"/>
            <RadioButton x:Name="AlignRight" Content="▶ Right" Style="{StaticResource Radio}"/>
        </StackPanel>

        <!-- PROMPTER MODE -->
        <TextBlock Text="PROMPTER MODE" Style="{StaticResource SectionLabel}"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <RadioButton x:Name="ModeNotch" Content="📌 Notch" Style="{StaticResource Radio}" IsChecked="True"/>
            <RadioButton x:Name="ModeFloating" Content="🪟 Floating" Style="{StaticResource Radio}"/>
        </StackPanel>

        <!-- COUNTDOWN TIMER -->
        <TextBlock Text="COUNTDOWN BEFORE START" Style="{StaticResource SectionLabel}"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <RadioButton x:Name="Countdown0" Content="Off" Style="{StaticResource Radio}"/>
            <RadioButton x:Name="Countdown3" Content="3 sec" Style="{StaticResource Radio}" IsChecked="True"/>
            <RadioButton x:Name="Countdown5" Content="5 sec" Style="{StaticResource Radio}"/>
        </StackPanel>

        <!-- FONT SIZE -->
        <TextBlock Text="PROMPTER FONT SIZE" Style="{StaticResource SectionLabel}"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
            <Slider x:Name="FontSizeSlider" Minimum="14" Maximum="72" Value="22"
                    Width="260" VerticalAlignment="Center"
                    TickFrequency="2" IsSnapToTickEnabled="True"/>
            <TextBlock x:Name="FontSizeDisplay" Text="22" FontSize="13" Foreground="#CCC"
                       VerticalAlignment="Center" Margin="12,0,0,0" Width="30"/>
        </StackPanel>

        <!-- BUTTONS -->
        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Content="Cancel" Style="{StaticResource CancelBtn}" Click="Cancel_Click"/>
            <Button Content="Save" Style="{StaticResource SaveBtn}" Click="Save_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
