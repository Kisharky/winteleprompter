<Window x:Class="MoodyClone.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="420" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="#1C1C1E"
        Foreground="White"
        FontFamily="Segoe UI"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <Style x:Key="SettingsLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="SettingsCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#3A3A3C"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="SettingsRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>
        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Background" Value="#30D158"/>
            <Setter Property="Foreground" Value="#1C1C1E"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#34E060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="⚙ Settings" FontSize="20" FontWeight="SemiBold" Foreground="White"/>

        <!-- Microphone -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="MICROPHONE" Style="{StaticResource SettingsLabel}"/>
            <ComboBox x:Name="MicSelector" Style="{StaticResource SettingsCombo}"/>
        </StackPanel>

        <!-- Text Color -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="TEXT COLOR" Style="{StaticResource SettingsLabel}"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="ColorWhite" Content="White" Style="{StaticResource SettingsRadio}" IsChecked="True"/>
                <RadioButton x:Name="ColorYellow" Content="Yellow" Style="{StaticResource SettingsRadio}"/>
                <RadioButton x:Name="ColorGreen" Content="Green" Style="{StaticResource SettingsRadio}"/>
            </StackPanel>
        </StackPanel>

        <!-- Prompter Mode -->
        <StackPanel Grid.Row="6">
            <TextBlock Text="PROMPTER MODE" Style="{StaticResource SettingsLabel}"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="ModeNotch" Content="📌 Notch" Style="{StaticResource SettingsRadio}" IsChecked="True"/>
                <RadioButton x:Name="ModeFloating" Content="🪟 Floating" Style="{StaticResource SettingsRadio}"/>
            </StackPanel>
        </StackPanel>

        <!-- Font Size -->
        <StackPanel Grid.Row="8">
            <TextBlock Text="PROMPTER FONT SIZE" Style="{StaticResource SettingsLabel}"/>
            <StackPanel Orientation="Horizontal">
                <Slider x:Name="FontSizeSlider" Minimum="24" Maximum="96" Value="48"
                        Width="240" VerticalAlignment="Center"
                        TickFrequency="4" IsSnapToTickEnabled="True"/>
                <TextBlock x:Name="FontSizeDisplay" Text="48" FontSize="13" Foreground="#CCC"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Save -->
        <StackPanel Grid.Row="10" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Content="Cancel" Padding="16,8" Margin="0,0,8,0" Click="Cancel_Click"
                    Background="#2C2C2E" Foreground="#E0E0E0" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Save" Style="{StaticResource SaveBtn}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
