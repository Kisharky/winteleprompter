<Window x:Class="MoodyClone.Views.PrompterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prompter"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Width="700" Height="300"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Prompter control button -->
        <Style x:Key="PrompterBtn" TargetType="Button">
            <Setter Property="Background" Value="#44FFFFFF"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#66FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#88FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active speed button -->
        <Style x:Key="SpeedBtnActive" TargetType="Button" BasedOn="{StaticResource PrompterBtn}">
            <Setter Property="Background" Value="#30D158"/>
            <Setter Property="Foreground" Value="#1C1C1E"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Stop button -->
        <Style x:Key="StopBtn" TargetType="Button" BasedOn="{StaticResource PrompterBtn}">
            <Setter Property="Background" Value="#FF453A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <!-- Main container -->
    <Grid x:Name="RootGrid">
        <Border x:Name="MainBorder"
                Background="#F01C1C1E"
                CornerRadius="0,0,12,12"
                ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Color="Black"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="4"/>    <!-- Voice beam -->
                    <RowDefinition Height="*"/>    <!-- Text area -->
                    <RowDefinition Height="40"/>   <!-- Controls -->
                </Grid.RowDefinitions>

                <!-- ====== VOICE FEEDBACK BEAM ====== -->
                <Grid Grid.Row="0" Background="#111113">
                    <Rectangle x:Name="VoiceBeam"
                               Height="3"
                               Fill="#30D158"
                               HorizontalAlignment="Center"
                               Width="0"
                               RadiusX="1.5" RadiusY="1.5"
                               Opacity="0.85"/>
                </Grid>

                <!-- ====== TEXT DISPLAY ====== -->
                <Grid Grid.Row="1" ClipToBounds="True">
                    <!-- Reading guide line (at vertical center) -->
                    <Border x:Name="ReadingGuide"
                            VerticalAlignment="Center"
                            Height="2"
                            HorizontalAlignment="Stretch"
                            IsHitTestVisible="False"
                            Opacity="0.3">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#30D158" Offset="0.2"/>
                                <GradientStop Color="#30D158" Offset="0.8"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Scroll viewer for text -->
                    <ScrollViewer x:Name="TextScroller"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Hidden"
                                  IsHitTestVisible="True"
                                  Focusable="False"
                                  PanningMode="None">
                        <StackPanel>
                            <!-- Top padding to center first line -->
                            <Border x:Name="TopPadding" Height="100"/>

                            <!-- Script text -->
                            <TextBlock x:Name="ScriptText"
                                       FontSize="48"
                                       LineHeight="64"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Foreground="White"
                                       Padding="24,0"
                                       FontFamily="Segoe UI"/>

                            <!-- End of text indicator -->
                            <StackPanel x:Name="EndIndicator" Margin="0,40,0,60" Opacity="0.5">
                                <Rectangle Width="60" Height="1" Fill="#666" Margin="0,0,0,10"
                                           HorizontalAlignment="Center" RadiusX="0.5" RadiusY="0.5"/>
                                <TextBlock Text="✓ End of script" FontSize="14" Foreground="#666"
                                           TextAlignment="Center" FontStyle="Italic"/>
                            </StackPanel>

                            <!-- Bottom padding -->
                            <Border x:Name="BottomPadding" Height="100"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Fade overlays -->
                    <Border VerticalAlignment="Top" Height="40" IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#F01C1C1E" Offset="0"/>
                                <GradientStop Color="#001C1C1E" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border VerticalAlignment="Bottom" Height="40" IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#001C1C1E" Offset="0"/>
                                <GradientStop Color="#F01C1C1E" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>

                <!-- ====== CONTROLS BAR ====== -->
                <Border Grid.Row="2" Background="#1A1A1C" BorderBrush="#333336" BorderThickness="0,1,0,0">
                    <DockPanel Margin="10,0">
                        <!-- Stop button on left -->
                        <Button DockPanel.Dock="Left" Content="■ Stop" Style="{StaticResource StopBtn}"
                                Click="Stop_Click" Padding="12,5"/>

                        <!-- Controls on right -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Pause indicator -->
                            <TextBlock x:Name="PauseIndicator" Text="⏸ PAUSED" FontSize="11" Foreground="#FFCC00"
                                       VerticalAlignment="Center" Margin="0,0,8,0" Visibility="Collapsed"
                                       FontWeight="SemiBold"/>

                            <!-- Mode toggle -->
                            <Button x:Name="ModeToggle" Content="📌 Notch" Style="{StaticResource PrompterBtn}"
                                    Click="ModeToggle_Click" ToolTip="Toggle Notch/Floating"/>
                            <Rectangle Width="1" Height="18" Fill="#444" Margin="6,0"/>

                            <!-- Voice toggle -->
                            <Button x:Name="VoiceToggle" Content="🎤 Voice" Style="{StaticResource PrompterBtn}"
                                    Click="VoiceToggle_Click" ToolTip="Toggle voice scrolling"/>
                        </StackPanel>

                        <!-- Speed controls center -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button x:Name="Speed1" Content="1×" Style="{StaticResource SpeedBtnActive}"
                                    Click="Speed_Click" Tag="1"/>
                            <Button x:Name="Speed15" Content="1.5×" Style="{StaticResource PrompterBtn}"
                                    Click="Speed_Click" Tag="1.5"/>
                            <Button x:Name="Speed2" Content="2×" Style="{StaticResource PrompterBtn}"
                                    Click="Speed_Click" Tag="2"/>
                            <Button x:Name="Speed3" Content="3×" Style="{StaticResource PrompterBtn}"
                                    Click="Speed_Click" Tag="3"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- ====== RESIZE GRIP (floating mode) ====== -->
                <Thumb x:Name="ResizeGrip" Grid.Row="2"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       Width="16" Height="16" Cursor="SizeNWSE"
                       DragDelta="ResizeGrip_DragDelta"
                       Opacity="0.4">
                    <Thumb.Template>
                        <ControlTemplate>
                            <Canvas Width="16" Height="16">
                                <Line X1="14" Y1="4" X2="4" Y2="14" Stroke="#888" StrokeThickness="1"/>
                                <Line X1="14" Y1="8" X2="8" Y2="14" Stroke="#888" StrokeThickness="1"/>
                                <Line X1="14" Y1="12" X2="12" Y2="14" Stroke="#888" StrokeThickness="1"/>
                            </Canvas>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>

                <!-- ====== DRAG HANDLE (for floating mode) ====== -->
                <Border x:Name="DragHandle" Grid.Row="0" Grid.RowSpan="1"
                        Background="Transparent" Cursor="SizeAll"
                        MouseLeftButtonDown="DragHandle_MouseLeftButtonDown"/>
            </Grid>
        </Border>
    </Grid>
</Window>
