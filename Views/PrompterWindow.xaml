<Window x:Class="MoodyClone.Views.PrompterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prompter"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Width="460" Height="160"
        WindowStartupLocation="Manual"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Hover overlay button -->
        <Style x:Key="OverlayBtn" TargetType="Button">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#77FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active speed button -->
        <Style x:Key="ActiveSpeedBtn" TargetType="Button" BasedOn="{StaticResource OverlayBtn}">
            <Setter Property="Background" Value="#30D158"/>
            <Setter Property="Foreground" Value="#000"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Stop button -->
        <Style x:Key="StopBtn" TargetType="Button" BasedOn="{StaticResource OverlayBtn}">
            <Setter Property="Background" Value="#FF453A"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <!-- Outer clip for rounded bottom corners -->
    <Grid x:Name="RootGrid">
        <Border x:Name="MainBorder"
                Background="#000000"
                CornerRadius="0,0,18,18"
                ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="8" Opacity="0.7" Color="Black"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="3"/>   <!-- Voice beam -->
                    <RowDefinition Height="*"/>   <!-- Text -->
                    <RowDefinition Height="0"/>   <!-- Controls (hidden by default, expanded on hover) -->
                </Grid.RowDefinitions>

                <!-- ====== VOICE FEEDBACK BEAM ====== -->
                <Grid Grid.Row="0" Background="Transparent">
                    <Rectangle x:Name="VoiceBeam"
                               Height="2"
                               Fill="#30D158"
                               HorizontalAlignment="Center"
                               Width="0"
                               RadiusX="1" RadiusY="1"
                               Opacity="0"/>
                </Grid>

                <!-- ====== TEXT AREA ====== -->
                <Grid Grid.Row="1" ClipToBounds="True">

                    <!-- Reading guide: subtle line at center -->
                    <Border VerticalAlignment="Center" Height="1"
                            HorizontalAlignment="Stretch" IsHitTestVisible="False" Opacity="0.15">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="White" Offset="0.2"/>
                                <GradientStop Color="White" Offset="0.8"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Scrollable text -->
                    <ScrollViewer x:Name="TextScroller"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Hidden"
                                  Focusable="False" IsHitTestVisible="True">
                        <StackPanel>
                            <Border x:Name="TopPadding" Height="60"/>

                            <TextBlock x:Name="ScriptText"
                                       FontSize="22"
                                       LineHeight="30"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Foreground="White"
                                       FontWeight="Normal"
                                       Padding="28,0"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"/>

                            <!-- End indicator -->
                            <Border x:Name="EndIndicator" Margin="0,24,0,0" Opacity="0">
                                <Rectangle Width="32" Height="2" Fill="#444"
                                           HorizontalAlignment="Center"
                                           RadiusX="1" RadiusY="1"/>
                            </Border>

                            <Border x:Name="BottomPadding" Height="60"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Top fade -->
                    <Border VerticalAlignment="Top" Height="36" IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FF000000" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Bottom fade -->
                    <Border VerticalAlignment="Bottom" Height="36" IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0"/>
                                <GradientStop Color="#FF000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>

                <!-- ====== HOVER CONTROLS OVERLAY ====== 
                     Sits on top of the text; animated in/out on hover -->
                <Border x:Name="HoverControls"
                        Grid.Row="0" Grid.RowSpan="3"
                        VerticalAlignment="Bottom"
                        Height="36"
                        Background="#CC000000"
                        CornerRadius="0,0,18,18"
                        Opacity="0"
                        IsHitTestVisible="False">
                    <Grid Margin="12,0">
                        <!-- Stop -->
                        <Button DockPanel.Dock="Left" Content="■ Stop" 
                                Style="{StaticResource StopBtn}"
                                Click="Stop_Click"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"/>

                        <!-- Pause indicator -->
                        <TextBlock x:Name="PauseIndicator" Text="⏸"
                                   FontSize="13" Foreground="#FFCC00"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"/>

                        <!-- Right controls -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button x:Name="Speed1" Content="1×" Style="{StaticResource ActiveSpeedBtn}" Click="Speed_Click" Tag="1"/>
                            <Button x:Name="Speed15" Content="1.5×" Style="{StaticResource OverlayBtn}" Click="Speed_Click" Tag="1.5"/>
                            <Button x:Name="Speed2" Content="2×" Style="{StaticResource OverlayBtn}" Click="Speed_Click" Tag="2"/>
                            <Button x:Name="Speed3" Content="3×" Style="{StaticResource OverlayBtn}" Click="Speed_Click" Tag="3"/>
                            <Rectangle Width="1" Height="14" Fill="#444" Margin="6,0"/>
                            <Button x:Name="VoiceToggle" Content="🎤" Style="{StaticResource OverlayBtn}" Click="VoiceToggle_Click" ToolTip="Voice scroll" Padding="7,4"/>
                            <Button x:Name="ModeToggle" Content="🪟" Style="{StaticResource OverlayBtn}" Click="ModeToggle_Click" ToolTip="Switch to floating" Padding="7,4"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Drag area (top strip, notch mode) -->
                <Border x:Name="DragHandle" Grid.Row="0" Grid.RowSpan="2"
                        Background="Transparent" Cursor="SizeAll"
                        MouseLeftButtonDown="DragHandle_MouseLeftButtonDown"/>

                <!-- Resize grip (floating mode only) -->
                <Thumb x:Name="ResizeGrip" Grid.Row="2"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                       Width="14" Height="14" Cursor="SizeNWSE"
                       DragDelta="ResizeGrip_DragDelta" Visibility="Collapsed" Opacity="0.4">
                    <Thumb.Template>
                        <ControlTemplate>
                            <Canvas Width="14" Height="14">
                                <Line X1="12" Y1="3" X2="3" Y2="12" Stroke="#888" StrokeThickness="1"/>
                                <Line X1="12" Y1="7" X2="7" Y2="12" Stroke="#888" StrokeThickness="1"/>
                                <Line X1="12" Y1="11" X2="11" Y2="12" Stroke="#888" StrokeThickness="1"/>
                            </Canvas>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>
            </Grid>
        </Border>

        <!-- ====== COUNTDOWN OVERLAY ====== -->
        <!-- Sits above everything; fades out after countdown completes -->
        <Border x:Name="CountdownOverlay"
                Background="#000000"
                CornerRadius="0,0,18,18"
                IsHitTestVisible="True">
            <Grid>
                <!-- Countdown number -->
                <TextBlock x:Name="CountdownText"
                           Text="3"
                           FontSize="56"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI Variable Display, Segoe UI"/>

                <!-- Small "Get ready..." label above the number -->
                <TextBlock Text="Get ready..."
                           FontSize="11"
                           Foreground="#666"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,-60,0,0"
                           FontFamily="Segoe UI"/>
            </Grid>
        </Border>
    </Grid>
</Window>

